# store deploy — copy to .env. TLS is terminated by the deployment environment.

# ── Identities ───────────────────────────────────────────────────────────────
# Connector settlement identity (BIP-39). Empty → pre-funded anvil acct-0 devnet
# fallback. If set, ALSO update routes[].settlementAddresses.evm in connector.yaml
# to the EVM address the connector prints at boot.
TOON_MNEMONIC=
# REQUIRED: store Nostr identity. Generate: openssl rand -hex 32
STORE_NOSTR_SECRET_KEY=

# ── Arweave wallet ───────────────────────────────────────────────────────────
# base64(JSON RSA JWK) of a funded Arweave wallet. Empty → ephemeral free-tier
# (≤100KB uploads, no deposit; the ephemeral key rotates on every restart).
STORE_ARWEAVE_JWK_B64=
# Flat per-job fee (base units). Keep aligned with connector.yaml routes[].price.
FEE_PER_JOB=10

# ── Images ───────────────────────────────────────────────────────────────────
# The connector image baked into store-connector (pin a concrete semver).
CONNECTOR_TAG=3.24.2
# The published store-connector image (prod: pin a tag and `up` without --build).
STORE_CONNECTOR_IMAGE=ghcr.io/toon-protocol/store-connector:latest
# The published store app image.
STORE_IMAGE=ghcr.io/toon-protocol/store:latest

# ── Ports ────────────────────────────────────────────────────────────────────
EDGE_PORT=3000

# ── Misc ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Devnet RPC serves a self-signed cert — DEVNET ONLY (never for the public edge).
NODE_TLS_REJECT_UNAUTHORIZED=0
